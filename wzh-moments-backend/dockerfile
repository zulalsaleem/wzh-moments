# Node.js 18 Alpine = lightweight Linux (5MB vs 300MB)
FROM node:18-alpine

# Working directory inside container
WORKDIR /app

# Copy package.json FIRST (Docker caching trick)
# If packages unchanged → skips npm install on rebuild
COPY package*.json ./

# Install only production dependencies
RUN npm install --production

# Copy rest of source code
COPY . .

EXPOSE 8000

# Health check - docker-compose uses this to know
# backend is ready before starting frontend
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s \
  CMD wget -qO- http://localhost:8000/api/health || exit 1

CMD ["node", "src/server.js"]